--- !u!114 &382217988
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 382217986}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 24f7492f14c25ab4c84f5deaaeb1aaf8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogues:
  - lines:
    - "Hotaru: \u0110\xE2y l\xE0 \u0111\xE2u...?"
    cameraIndex: 0
  - lines:
    - "Vua: Ch\xE0o m\u1EEBng ng\u01B0\u01A1i, anh h\xF9ng \u0111\u1EBFn t\u1EEB
      th\u1EBF gi\u1EDBi kh\xE1c!"
    cameraIndex: 1
  - lines:
    - "Vua: Ch\xFAng ta \u0111ang \u0111\u1ED1i m\u1EB7t v\u1EDBi hi\u1EC3m h\u1ECDa
      di\u1EC7t vong t\u1EEB Ma V\u01B0\u01A1ng."
    cameraIndex: 1
  - lines:
    - "Vua: Xin h\xE3y ra tay c\u1EE9u l\u1EA5y v\u01B0\u01A1ng qu\u1ED1c c\u1EE7a
      ch\xFAng ta!"
    cameraIndex: 1
  - lines:
    - "Hotaru: ...T\xF4i \xE1!?"
    cameraIndex: 0
  - lines:
    - "N\u1EEF th\u1EA7n: \u0110\xFAng v\u1EADy h\u1EE1i d\u0169ng gi\u1EA3, ta l\xE0
      n\u1EEF th\u1EA7n b\u1EA3o h\u1ED9 c\u1EE7a th\u1EBF gi\u1EDBi n\xE0y"
    cameraIndex: 2
  - lines:
    - "N\u1EEF th\u1EA7n: Ta \u0111\xE3 ban cho ng\u01B0\u01A1i m\u1ED9t ph\u1EA7n
      s\u1EE9c m\u1EA1nh \u0111\u1EC3 chi\u1EBFn \u0111\u1EA5u."
    cameraIndex: 2
  - lines:
    - "N\u1EEF th\u1EA7n: H\xE3y nh\u1EA5n [I] \u0111\u1EC3 m\u1EDF tr\u1EA1ng th\xE1i
      v\xE0 ki\u1EC3m tra n\u0103ng l\u1EF1c c\u1EE7a ng\u01B0\u01A1i."
    cameraIndex: 2
  - lines:
    - "Vua: T\u1ED1t l\u1EAFm, anh h\xF9ng! S\u1EBD c\xF3 ng\u01B0\u1EDDi l\xEDnh
      \u0111\u1EE3i ng\u01B0\u01A1i \u1EDF c\u1ED5ng \u0111\u1EC3 gi\xFAp ng\u01B0\u01A1i
      l\xE0m quen vi\u1EC7c chi\u1EBFn \u0111\u1EA5u"
    cameraIndex: 1
  cameras:
  - {fileID: 80607024}
  - {fileID: 1192161714}
  - {fileID: 1744078179}
