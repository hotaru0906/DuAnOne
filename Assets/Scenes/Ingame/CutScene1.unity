--- !u!114 &890758231
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 890758229}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: be10ba217759147468ebbd7a0da49ecb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  steps:
  - dialogueLines:
    - "Hotaru \u2013 m\u1ED9t sinh vi\xEAn b\xECnh th\u01B0\u1EDDng t\u1EA1i tr\u01B0\u1EDDng
      FPT Polytechnic, v\u1EDBi cu\u1ED9c s\u1ED1ng c\u0169ng b\xECnh th\u01B0\u1EDDng
      n\u1ED1t."
    - "Nh\u01B0ng c\u1EADu kh\xF4ng h\u1EC1 bi\u1EBFt r\u1EB1ng..."
    - "H\xF4m nay s\u1EBD l\xE0 ng\xE0y \u0111\u1ECBnh m\u1EC7nh thay \u0111\u1ED5i
      cu\u1ED9c \u0111\u1EDDi c\u1EADu m\xE3i m\xE3i."
    image: {fileID: 21300000, guid: d6688f645cfbc92448fbb8c1bafb6077, type: 3}
  - dialogueLines:
    - "H\u1EDF!?"
    - "D\u01B0\u1EDBi ch\xE2n c\u1EADu... m\u1ED9t v\xF2ng tr\xF2n ph\xE1t s\xE1ng!?"
    - "G\xEC v\u1EADy tr\u1EDDi\u2014\u0111\xE2y l\xE0 cosplay \xE0?!"
    image: {fileID: 21300000, guid: ed85e50a4c9174b49925bff90ee34d5d, type: 3}
  - dialogueLines:
    - "\xC1nh s\xE1ng nu\u1ED1t ch\u1EEDng l\u1EA5y Hotaru!"
    - "Kh\xF4ng k\u1ECBp k\xEAu c\u1EE9u... c\u1EADu b\u1ECB k\xE9o \u0111i!"
    - "...D\u1ECACH CHUY\u1EC2N HO\xC0N T\u1EA4T."
    image: {fileID: 21300000, guid: d8c10e7f9f4fbf541b3b5130d87eacb2, type: 3}
  - dialogueLines:
    - "H\u1EA3!? \u0110\xE2y l\xE0 \u0111\xE2u...?"
    - "Tr\u01B0\u1EDBc m\u1EB7t c\u1EADu l\xE0 nh\u1EEFng ng\u01B0\u1EDDi m\u1EB7c
      gi\xE1p s\u1EAFt, c\u1EA7m gi\xE1o..."
    - "Ch\u1EAFc ch\u1EAFn... \u0111\xE2y l\xE0... ISEKAI!!"
    image: {fileID: 21300000, guid: bdef5ffc5b3e6f7489fa31dac4330a09, type: 3}
  - dialogueLines:
    - "Ch\xE0o m\u1EEBng, d\u0169ng s\u0129 \u0111\u01B0\u1EE3c tri\u1EC7u h\u1ED3i!"
    - "Xin l\u1ED7i v\xEC \u0111\xE3 k\xE9o c\u1EADu t\u1EDBi \u0111\xE2y m\xE0 ch\u01B0a
      h\u1ECFi tr\u01B0\u1EDBc..."
    - "Nh\u01B0ng\u2014h\xE3y c\u1EE9u l\u1EA5y v\u01B0\u01A1ng qu\u1ED1c ch\xFAng
      t\xF4i!"
    image: {fileID: 21300000, guid: 7c0fd5067f67d984dba4d5880a9992e1, type: 3}
  cutsceneImage: {fileID: 321933382}
  blackScreen: {fileID: 428812910}
  nextSceneName: Castle
  fadeDuration: 1
  skipButton: {fileID: 965362577}
